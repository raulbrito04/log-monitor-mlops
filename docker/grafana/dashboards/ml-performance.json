{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "ML F1 Score",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 4},
      "targets": [{"expr": "logmonitor_ml_model_f1_score", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "textMode": "value"}
    },
    {
      "type": "stat",
      "title": "Anomaly Share",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 4},
      "targets": [{"expr": "sum(logmonitor_ml_predictions_total{prediction=\"anomaly\"}) / clamp_min(sum(logmonitor_ml_predictions_total), 1)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "textMode": "value"}
    },
    {
      "type": "stat",
      "title": "Data Freshness",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 4},
      "targets": [{"expr": "logmonitor_data_freshness_seconds", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "textMode": "value"}
    },
    {
      "type": "timeseries",
      "title": "Predictions by Class",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "sum(logmonitor_ml_predictions_total) by (prediction)", "legendFormat": "{{prediction}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Alert Creation Velocity",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "sum(rate(logmonitor_alerts_total[5m])) by (alert_type)", "legendFormat": "{{alert_type}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "SLO Signals",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "targets": [
        {"expr": "avg_over_time(up{job=\"flask_app\"}[1h])", "legendFormat": "availability", "refId": "A"},
        {"expr": "logmonitor_ml_model_f1_score", "legendFormat": "ml_f1", "refId": "B"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(flask_http_request_duration_seconds_bucket[5m])))", "legendFormat": "latency_p95", "refId": "C"}
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["logmonitor", "ml"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "title": "Log Monitor - ML Performance",
  "version": 1
}
